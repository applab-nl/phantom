// Default Phantom layout for Zellij
// Top pane: AI agent (focused)
// Bottom pane: two shells side by side

keybinds {
    normal {
        // Pass Shift+Enter through to terminal apps (e.g., Claude Code newline)
        bind "Shift Enter" { Write 27 91 49 51 59 50 117; }
    }
}

layout {
    pane split_direction="vertical" {
        pane size="50%" focus=true {
            name "agent"
            command "claude"
        }
        pane size="50%" split_direction="horizontal" {
            pane {
                name "shell"
            }
            pane {
                name "shell2"
            }
        }
    }
}
